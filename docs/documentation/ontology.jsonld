  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://example.org/mdr-ontology#CorrectiveActionStatus"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Closed"
  } ]
}, {
  "@id" : "https://example.org/mdr-ontology#CorrectiveAction",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "An action taken to eliminate or reduce the risk associated with a medical device incident."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Corrective Action"
  } ]
}, {
  "@id" : "https://example.org/mdr-ontology#CorrectiveActionStatus",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "The current state of a corrective action, indicating whether it is open, ongoing, or closed."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Status"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://example.org/mdr-ontology#CorrectiveAction"
  } ]
