}, {
  "@id" : "https://example.org/mdr-ontology#",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://purl.org/dc/terms/abstract" : [ {
    "@value" : "This ontology models medical devices, incidents, risks, and corrective actions under European MDR/IVDR regulations. It captures the relationships between devices, manufacturers, risk classifications, and incident management processes, supporting semantic interoperability and structured data representation. The ontology was developed as part of the PAC2 assignment for the knowledge representation course at the UOC."
  } ],
  "http://purl.org/dc/terms/created" : [ {
    "@value" : "April 2026"
  } ],
  "http://purl.org/dc/terms/creator" : [ {
    "@value" : "Joan Solà"
  } ],
  "http://purl.org/dc/terms/description" : [ {
    "@value" : "Ontology developed as an exercise for a course at the Universitat Oberta de Catalunya (UOC). It models medical devices, incidents, risks, and corrective actions under MDR/IVDR regulations."
  } ],
  "http://purl.org/dc/terms/license" : [ {
    "@value" : "https://creativecommons.org/publicdomain/zero/1.0/"
  } ],
  "http://purl.org/dc/terms/subject" : [ {
    "@value" : "Representació del coneixement PAC2 - Spring 2026 - UOC"
  } ],
  "http://purl.org/dc/terms/title" : [ {
    "@value" : "Medical Device Incident Ontology"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@value" : "DBpedia. https://dbpedia.org/"
  }, {
    "@value" : "European Union. Regulation (EU) 2017/745 on medical devices (MDR). https://en.wikipedia.org/wiki/Regulation_(EU)_2017/745"
  }, {
    "@value" : "European Union. Regulation (EU) 2017/746 on in vitro diagnostic medical devices (IVDR). https://en.wikipedia.org/wiki/Regulation_(EU)_2017/746"
  }, {
    "@value" : "Linked Open Vocabularies (LOV). https://lov.linkeddata.es/"
  } ]
}, {
  "@id" : "https://example.org/mdr-ontology#ActionType",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "A classification of corrective actions according to their nature or purpose, such as recall, safety alert, or in-situ correction."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Action Type"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://example.org/mdr-ontology#CorrectiveAction"
  } ]
}, {
  "@id" : "https://example.org/mdr-ontology#Closed",
