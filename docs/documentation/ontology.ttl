       rdfs:label "UDI DI" .


#################################################################
#    Classes
#################################################################

###  https://example.org/mdr-ontology#ActionType
:ActionType rdf:type owl:Class ;
            rdfs:subClassOf :CorrectiveAction ;
            rdfs:comment "A classification of corrective actions according to their nature or purpose, such as recall, safety alert, or in-situ correction." ;
            rdfs:label "Action Type" .


###  https://example.org/mdr-ontology#CorrectiveAction
:CorrectiveAction rdf:type owl:Class ;
                  rdfs:comment "An action taken to eliminate or reduce the risk associated with a medical device incident." ;
                  rdfs:label "Corrective Action" .


###  https://example.org/mdr-ontology#CorrectiveActionStatus
:CorrectiveActionStatus rdf:type owl:Class ;
                        rdfs:subClassOf :CorrectiveAction ;
                        rdfs:comment "The current state of a corrective action, indicating whether it is open, ongoing, or closed." ;
                        rdfs:label "Status" .


###  https://example.org/mdr-ontology#Device
:Device rdf:type owl:Class ;
        rdfs:subClassOf [ rdf:type owl:Restriction ;
                          owl:onProperty :hasManufacturer ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onClass :Manufacturer
                        ] ;
        rdfs:comment "A medical device regulated under MDR or IVDR, including implantable, active or diagnostic devices." ;
        rdfs:label "Device" .


###  https://example.org/mdr-ontology#DeviceType
:DeviceType rdf:type owl:Class ;
            rdfs:subClassOf :Device ;
            rdfs:comment "A classification that describes the functional or structural characteristics of a medical device, such as implantable or active." ;
            rdfs:label "Device Type" .


###  https://example.org/mdr-ontology#Incident
:Incident rdf:type owl:Class ;
          rdfs:comment "An event involving a medical device that may lead to or has led to harm, malfunction or safety issues." ;
          rdfs:label "Incident" .


###  https://example.org/mdr-ontology#IncidentType
:IncidentType rdf:type owl:Class ;
              rdfs:subClassOf :Incident ;
              rdfs:comment "A categorization of incidents based on their severity or nature, such as serious incident or near-miss." ;
              rdfs:label "Incident Type" .


###  https://example.org/mdr-ontology#Manufacturer
:Manufacturer rdf:type owl:Class ;
              rdfs:comment "An organization responsible for designing, manufacturing or placing a medical device on the market." ;
              rdfs:label "Manufacturer" .


###  https://example.org/mdr-ontology#ProbabilityLevel
:ProbabilityLevel rdf:type owl:Class ;
                  rdfs:subClassOf :Risk ;
                  rdfs:comment "A classification indicating the likelihood of occurrence of a risk, typically expressed as low, medium, or high." ;
                  rdfs:label "Probability Level" .


###  https://example.org/mdr-ontology#RegulatoryFramework
:RegulatoryFramework rdf:type owl:Class ;
                     rdfs:subClassOf :Device ;
                     rdfs:comment "A regulatory classification that determines the legal framework applicable to a medical device, such as MDR or IVDR." ;
                     rdfs:label "Regulatory Framework" .


###  https://example.org/mdr-ontology#Risk
:Risk rdf:type owl:Class ;
      rdfs:comment "A potential source of harm associated with the use or malfunction of a medical device." ;
      rdfs:label "Risk" .


###  https://example.org/mdr-ontology#RiskCategory
:RiskCategory rdf:type owl:Class ;
              rdfs:subClassOf :Risk ;
              rdfs:comment "A high-level classification of risks based on their origin, such as device-related or patient-related risks." ;
              rdfs:label "Category" .


###  https://example.org/mdr-ontology#RiskClass
:RiskClass rdf:type owl:Class ;
           rdfs:subClassOf :Device ;
           rdfs:comment "A classification indicating the level of regulatory risk associated with a device, typically based on safety and intended use." ;
           rdfs:label "Risk Class" .


###  https://example.org/mdr-ontology#SeverityLevel
:SeverityLevel rdf:type owl:Class ;
               rdfs:subClassOf :Risk ;
               rdfs:comment "A classification indicating the potential impact or seriousness of a risk, such as minor, serious, or critical." ;
               rdfs:label "Severity Level" .


###  https://example.org/mdr-ontology#riskType
:riskType rdf:type owl:Class ;
          rdfs:subClassOf :Risk ;
          rdfs:comment "A more specific classification of risks within a category, describing the nature of the hazard, such as infection or mechanical failure." ;
          rdfs:label "Type" .


#################################################################
#    Individuals
#################################################################

###  https://example.org/mdr-ontology#Closed
:Closed rdf:type owl:NamedIndividual ,
                 :CorrectiveActionStatus ;
        rdfs:label "Closed" .


###  https://example.org/mdr-ontology#DEV_001
:DEV_001 rdf:type owl:NamedIndividual ,
                  :Device ;
         :hasManufacturer :MAN_001 ;
         :representsDeviceType :isActive ,
                               :isImplantable ;
         :representsRiskClass :classIII ;
         :deviceId "DEV-001" ;
         :deviceName "HeartMate 3 LVAD" ;
         :intendedPurpose "Ventricular assist device for end-stage heart failure" ;
         :regulatoryFramework "MDR" ;
         :udiDi "(01)00380740009095" ;
         rdfs:seeAlso <https://stanfordhealthcare.org/medical-treatments/l/lvad.html> .


###  https://example.org/mdr-ontology#DEV_002
:DEV_002 rdf:type owl:NamedIndividual ,
                  :Device ;
         :hasManufacturer :MAN_001 ;
