###  https://example.org/mdr-ontology#FSCA_001
:FSCA_001 rdf:type owl:NamedIndividual ,
                   :CorrectiveAction ;
          :adddressesIncident :INC_001 ;
          :representsActionType :safetyAlert ;
          :representsStatus :Open ;
          :actionDate "2024-02-01T00:00:00"^^xsd:dateTime ;
          :correctiveActionDescription "Safety alert issued to all implanting centres regarding anticoagulation protocol update for HeartMate 3 to reduce device thrombosis risk. INR target range revised to 2.0–3.0." ;
          :countriesAffected "EU-wide" ;
          :devicesAffected 850 ;
          :eudamedFscaRef "EU-FSCA-2024-000001" ;
          :fscaId "FSCA-001" ;
          :scope "All HeartMate 3 LVAD units implanted since 2020" .


###  https://example.org/mdr-ontology#FSCA_002
:FSCA_002 rdf:type owl:NamedIndividual ,
                   :CorrectiveAction ;
          :adddressesIncident :INC_002 ;
          :representsActionType :recall ;
          :representsStatus :Closed ;
          :actionDate "2024-02-28T00:00:00"^^xsd:dateTime ;
          :closureDate "2024-05-31T00:00:00"^^xsd:dateTime ;
          :correctiveActionDescription "Voluntary recall of affected Micra AV lots due to premature battery depletion. Replacement units provided. 97% of affected devices successfully replaced." ;
          :countriesAffected "EU-wide + UK" ;
          :devicesAffected 1240 ;
          :eudamedFscaRef "EU-FSCA-2024-000002" ;
          :fscaId "FSCA-002" ;
          :scope "Micra AV lots manufactured between 2022-09 and 2023-03" .


