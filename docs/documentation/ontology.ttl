###  https://example.org/mdr-ontology#DEV_008
:DEV_008 rdf:type owl:NamedIndividual ,
                  :Device ;
         :hasManufacturer :MAN_003 ;
         :representsDeviceType :isActive ,
                               :isReusable ;
