@prefix : <https://example.org/mdr-ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://example.org/mdr-ontology#> .

<https://example.org/mdr-ontology#> rdf:type owl:Ontology ;
                                     <http://purl.org/dc/terms/abstract> "This ontology models medical devices, incidents, risks, and corrective actions under European MDR/IVDR regulations. It captures the relationships between devices, manufacturers, risk classifications, and incident management processes, supporting semantic interoperability and structured data representation. The ontology was developed as part of the PAC2 assignment for the knowledge representation course at the UOC." ;
                                     <http://purl.org/dc/terms/created> "April 2026" ;
                                     <http://purl.org/dc/terms/creator> "Joan Solà" ;
                                     <http://purl.org/dc/terms/description> "Ontology developed as an exercise for a course at the Universitat Oberta de Catalunya (UOC). It models medical devices, incidents, risks, and corrective actions under MDR/IVDR regulations." ;
                                     <http://purl.org/dc/terms/license> "https://creativecommons.org/publicdomain/zero/1.0/" ;
                                     <http://purl.org/dc/terms/subject> "Representació del coneixement PAC2 - Spring 2026 - UOC" ;
                                     <http://purl.org/dc/terms/title> "Medical Device Incident Ontology" ;
                                     rdfs:seeAlso "DBpedia. https://dbpedia.org/" ,
                                                  "European Union. Regulation (EU) 2017/745 on medical devices (MDR). https://en.wikipedia.org/wiki/Regulation_(EU)_2017/745" ,
                                                  "European Union. Regulation (EU) 2017/746 on in vitro diagnostic medical devices (IVDR). https://en.wikipedia.org/wiki/Regulation_(EU)_2017/746" ,
                                                  "Linked Open Vocabularies (LOV). https://lov.linkeddata.es/" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/abstract
<http://purl.org/dc/terms/abstract> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/bibliographicCitation
<http://purl.org/dc/terms/bibliographicCitation> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/created
<http://purl.org/dc/terms/created> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
<http://purl.org/dc/terms/license> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/subject
<http://purl.org/dc/terms/subject> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
<http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  https://example.org/mdr-ontology#adddressesIncident
:adddressesIncident rdf:type owl:ObjectProperty ;
                    rdfs:domain :CorrectiveAction ;
                    rdfs:range :Incident ;
                    rdfs:label "addresses incident" .


###  https://example.org/mdr-ontology#affectsDeviceType
:affectsDeviceType rdf:type owl:ObjectProperty ;
                   rdfs:domain :Risk ;
                   rdfs:range :DeviceType ;
                   rdfs:label "affects device type" .


###  https://example.org/mdr-ontology#hasManufacturer
:hasManufacturer rdf:type owl:ObjectProperty ;
                 rdfs:domain :Device ;
                 rdfs:range [ rdf:type owl:Restriction ;
                              owl:onProperty :hasManufacturer ;
                              owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                              owl:onClass :Manufacturer
                            ] ;
                 rdfs:label "has manufacturer" .


###  https://example.org/mdr-ontology#hasRegulatoryFramework
:hasRegulatoryFramework rdf:type owl:ObjectProperty ;
                        rdfs:domain :Device ;
                        rdfs:range [ rdf:type owl:Restriction ;
                                     owl:onProperty :hasRegulatoryFramework ;
                                     owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                     owl:onClass :RegulatoryFramework
                                   ] ;
                        rdfs:label "has regulatory framework" .


###  https://example.org/mdr-ontology#hasRisk
:hasRisk rdf:type owl:ObjectProperty ;
         rdfs:domain :Incident ;
         rdfs:range [ rdf:type owl:Restriction ;
                      owl:onProperty :hasRisk ;
                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                      owl:onClass :Risk
                    ] ;
         rdfs:label "has risk" .


###  https://example.org/mdr-ontology#hasRiskProbability
:hasRiskProbability rdf:type owl:ObjectProperty ;
                    rdfs:domain :Risk ;
                    rdfs:range :ProbabilityLevel ;
                    rdfs:label "has risk probability" .


###  https://example.org/mdr-ontology#hasSeverityLevel
:hasSeverityLevel rdf:type owl:ObjectProperty ;
                  rdfs:domain :Risk ;
                  rdfs:range :SeverityLevel ;
                  rdfs:label "has severity level" .


###  https://example.org/mdr-ontology#involvesDevice
:involvesDevice rdf:type owl:ObjectProperty ;
                rdfs:domain :Incident ;
                rdfs:range :Device ;
                rdfs:label "involves device" .


###  https://example.org/mdr-ontology#reportedBy
:reportedBy rdf:type owl:ObjectProperty ;
            rdfs:domain :Incident ;
            rdfs:range :Manufacturer ;
            rdfs:label "reported by" .


###  https://example.org/mdr-ontology#representsActionType
:representsActionType rdf:type owl:ObjectProperty ;
                      rdfs:domain :CorrectiveAction ;
                      rdfs:range :ActionType ;
                      rdfs:label "represents action type" .


###  https://example.org/mdr-ontology#representsDeviceType
:representsDeviceType rdf:type owl:ObjectProperty ;
                      rdfs:domain :DeviceType ;
                      rdfs:range :Device ;
                      rdfs:label "represents device type" .


###  https://example.org/mdr-ontology#representsIncidentType
:representsIncidentType rdf:type owl:ObjectProperty ;
                        rdfs:domain :IncidentType ;
                        rdfs:range :Incident ;
                        rdfs:label "represents incident type" .


###  https://example.org/mdr-ontology#representsRiskCategory
:representsRiskCategory rdf:type owl:ObjectProperty ;
                        rdfs:domain :RiskCategory ;
                        rdfs:range :Risk ;
                        rdfs:label "represents risk category" .


###  https://example.org/mdr-ontology#representsRiskClass
:representsRiskClass rdf:type owl:ObjectProperty ;
                     rdfs:domain :RiskClass ;
                     rdfs:range :Device ;
                     rdfs:label "represents risk class" .


###  https://example.org/mdr-ontology#representsRiskType
:representsRiskType rdf:type owl:ObjectProperty ;
                    rdfs:domain :riskType ;
                    rdfs:range :Risk ;
                    rdfs:label "represents risk type" .


###  https://example.org/mdr-ontology#representsStatus
:representsStatus rdf:type owl:ObjectProperty ;
                  rdfs:domain :CorrectiveAction ;
                  rdfs:range :CorrectiveActionStatus ;
                  rdfs:label "represents status" .


