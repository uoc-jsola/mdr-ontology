###  https://example.org/mdr-ontology#RSK_001
:RSK_001 rdf:type owl:NamedIndividual ,
                  :Risk ;
         :affectsDeviceType :isActive ;
         :hasRiskProbability :low ;
         :hasSeverityLevel :severityCritical ;
         :representsRiskCategory :deviceFailure ;
         :representsRiskType :malfunctionRisk ;
         :imdrfCode "A0101" ;
         :riskDescription "Complete loss of electrical function leading to device shutdown" ;
         :riskId "RSK-001" ;
         :riskName "Device failure - electrical" .


