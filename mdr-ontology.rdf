    <owl:DatatypeProperty rdf:about="https://example.org/mdr-ontology#probabilityValue">
        <rdfs:domain rdf:resource="https://example.org/mdr-ontology#ProbabilityLevel"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label>Probability Value</rdfs:label>
    </owl:DatatypeProperty>
    


