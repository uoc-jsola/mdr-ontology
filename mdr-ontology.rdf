    <!-- https://example.org/mdr-ontology#representsRiskType -->

    <owl:ObjectProperty rdf:about="https://example.org/mdr-ontology#representsRiskType">
        <rdfs:domain rdf:resource="https://example.org/mdr-ontology#riskType"/>
        <rdfs:range rdf:resource="https://example.org/mdr-ontology#Risk"/>
