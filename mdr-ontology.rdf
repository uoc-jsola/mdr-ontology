                                        <swrl:propertyPredicate rdf:resource="https://example.org/mdr-ontology#representsDeviceType"/>
                                        <swrl:argument1 rdf:resource="urn:swrl:var#d"/>
                                        <swrl:argument2 rdf:resource="https://example.org/mdr-ontology#isActive"/>
                                    </rdf:Description>
                                </rdf:first>
                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
