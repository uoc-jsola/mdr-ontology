    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://example.org/mdr-ontology#ActionType -->

    <owl:Class rdf:about="https://example.org/mdr-ontology#ActionType">
        <rdfs:subClassOf rdf:resource="https://example.org/mdr-ontology#CorrectiveAction"/>
        <rdfs:comment>A classification of corrective actions according to their nature or purpose, such as recall, safety alert, or in-situ correction.</rdfs:comment>
        <rdfs:label>Action Type</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/mdr-ontology#CorrectiveAction -->

    <owl:Class rdf:about="https://example.org/mdr-ontology#CorrectiveAction">
        <rdfs:comment>An action taken to eliminate or reduce the risk associated with a medical device incident.</rdfs:comment>
        <rdfs:label>Corrective Action</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/mdr-ontology#CorrectiveActionStatus -->

    <owl:Class rdf:about="https://example.org/mdr-ontology#CorrectiveActionStatus">
        <rdfs:subClassOf rdf:resource="https://example.org/mdr-ontology#CorrectiveAction"/>
        <rdfs:comment>The current state of a corrective action, indicating whether it is open, ongoing, or closed.</rdfs:comment>
        <rdfs:label>Status</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/mdr-ontology#Device -->

    <owl:Class rdf:about="https://example.org/mdr-ontology#Device">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://example.org/mdr-ontology#hasManufacturer"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://example.org/mdr-ontology#Manufacturer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A medical device regulated under MDR or IVDR, including implantable, active or diagnostic devices.</rdfs:comment>
        <rdfs:label>Device</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/mdr-ontology#DeviceType -->

    <owl:Class rdf:about="https://example.org/mdr-ontology#DeviceType">
        <rdfs:subClassOf rdf:resource="https://example.org/mdr-ontology#Device"/>
        <rdfs:comment>A classification that describes the functional or structural characteristics of a medical device, such as implantable or active.</rdfs:comment>
        <rdfs:label>Device Type</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/mdr-ontology#Incident -->

    <owl:Class rdf:about="https://example.org/mdr-ontology#Incident">
        <rdfs:comment>An event involving a medical device that may lead to or has led to harm, malfunction or safety issues.</rdfs:comment>
        <rdfs:label>Incident</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/mdr-ontology#IncidentType -->

    <owl:Class rdf:about="https://example.org/mdr-ontology#IncidentType">
        <rdfs:subClassOf rdf:resource="https://example.org/mdr-ontology#Incident"/>
        <rdfs:comment>A categorization of incidents based on their severity or nature, such as serious incident or near-miss.</rdfs:comment>
        <rdfs:label>Incident Type</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/mdr-ontology#Manufacturer -->

    <owl:Class rdf:about="https://example.org/mdr-ontology#Manufacturer">
        <rdfs:comment>An organization responsible for designing, manufacturing or placing a medical device on the market.</rdfs:comment>
        <rdfs:label>Manufacturer</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/mdr-ontology#ProbabilityLevel -->

    <owl:Class rdf:about="https://example.org/mdr-ontology#ProbabilityLevel">
        <rdfs:subClassOf rdf:resource="https://example.org/mdr-ontology#Risk"/>
        <rdfs:comment>A classification indicating the likelihood of occurrence of a risk, typically expressed as low, medium, or high.</rdfs:comment>
        <rdfs:label>Probability Level</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/mdr-ontology#RegulatoryFramework -->

    <owl:Class rdf:about="https://example.org/mdr-ontology#RegulatoryFramework">
        <rdfs:subClassOf rdf:resource="https://example.org/mdr-ontology#Device"/>
        <rdfs:comment>A regulatory classification that determines the legal framework applicable to a medical device, such as MDR or IVDR.</rdfs:comment>
        <rdfs:label>Regulatory Framework</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/mdr-ontology#Risk -->

    <owl:Class rdf:about="https://example.org/mdr-ontology#Risk">
        <rdfs:comment>A potential source of harm associated with the use or malfunction of a medical device.</rdfs:comment>
        <rdfs:label>Risk</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/mdr-ontology#RiskCategory -->

    <owl:Class rdf:about="https://example.org/mdr-ontology#RiskCategory">
        <rdfs:subClassOf rdf:resource="https://example.org/mdr-ontology#Risk"/>
        <rdfs:comment>A high-level classification of risks based on their origin, such as device-related or patient-related risks.</rdfs:comment>
        <rdfs:label>Category</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/mdr-ontology#RiskClass -->

    <owl:Class rdf:about="https://example.org/mdr-ontology#RiskClass">
        <rdfs:subClassOf rdf:resource="https://example.org/mdr-ontology#Device"/>
        <rdfs:comment>A classification indicating the level of regulatory risk associated with a device, typically based on safety and intended use.</rdfs:comment>
        <rdfs:label>Risk Class</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/mdr-ontology#SeverityLevel -->

    <owl:Class rdf:about="https://example.org/mdr-ontology#SeverityLevel">
        <rdfs:subClassOf rdf:resource="https://example.org/mdr-ontology#Risk"/>
        <rdfs:comment>A classification indicating the potential impact or seriousness of a risk, such as minor, serious, or critical.</rdfs:comment>
        <rdfs:label>Severity Level</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/mdr-ontology#riskType -->

    <owl:Class rdf:about="https://example.org/mdr-ontology#riskType">
        <rdfs:subClassOf rdf:resource="https://example.org/mdr-ontology#Risk"/>
        <rdfs:comment>A more specific classification of risks within a category, describing the nature of the hazard, such as infection or mechanical failure.</rdfs:comment>
        <rdfs:label>Type</rdfs:label>
    </owl:Class>
    


