    </owl:ObjectProperty>
    


    <!-- https://example.org/mdr-ontology#reportedBy -->

    <owl:ObjectProperty rdf:about="https://example.org/mdr-ontology#reportedBy">
        <rdfs:domain rdf:resource="https://example.org/mdr-ontology#Incident"/>
        <rdfs:range rdf:resource="https://example.org/mdr-ontology#Manufacturer"/>
