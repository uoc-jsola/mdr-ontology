<?xml version="1.0"?>
<rdf:RDF xmlns="https://example.org/mdr-ontology#"
     xml:base="https://example.org/mdr-ontology"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:mdr-ontology="https://example.org/mdr-ontology#">
    <owl:Ontology rdf:about="https://example.org/mdr-ontology#">
        <terms:abstract>This ontology models medical devices, incidents, risks, and corrective actions under European MDR/IVDR regulations. It captures the relationships between devices, manufacturers, risk classifications, and incident management processes, supporting semantic interoperability and structured data representation. The ontology was developed as part of the PAC2 assignment for the knowledge representation course at the UOC.</terms:abstract>
        <terms:created>April 2026</terms:created>
        <terms:creator>Joan Solà</terms:creator>
        <terms:description>Ontology developed as an exercise for a course at the Universitat Oberta de Catalunya (UOC). It models medical devices, incidents, risks, and corrective actions under MDR/IVDR regulations.</terms:description>
        <terms:license>https://creativecommons.org/publicdomain/zero/1.0/</terms:license>
        <terms:subject>Representació del coneixement PAC2 - Spring 2026 - UOC</terms:subject>
        <terms:title>Medical Device Incident Ontology</terms:title>
        <rdfs:seeAlso>DBpedia. https://dbpedia.org/</rdfs:seeAlso>
        <rdfs:seeAlso>European Union. Regulation (EU) 2017/745 on medical devices (MDR). https://en.wikipedia.org/wiki/Regulation_(EU)_2017/745</rdfs:seeAlso>
        <rdfs:seeAlso>European Union. Regulation (EU) 2017/746 on in vitro diagnostic medical devices (IVDR). https://en.wikipedia.org/wiki/Regulation_(EU)_2017/746</rdfs:seeAlso>
        <rdfs:seeAlso>Linked Open Vocabularies (LOV). https://lov.linkeddata.es/</rdfs:seeAlso>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/dc/terms/abstract -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/abstract"/>
    


    <!-- http://purl.org/dc/terms/bibliographicCitation -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/bibliographicCitation"/>
    


    <!-- http://purl.org/dc/terms/created -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/created"/>
    


    <!-- http://purl.org/dc/terms/creator -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    


    <!-- http://purl.org/dc/terms/description -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/license -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://purl.org/dc/terms/subject -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/subject"/>
    


    <!-- http://purl.org/dc/terms/title -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled -->

    <owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://example.org/mdr-ontology#adddressesIncident -->

    <owl:ObjectProperty rdf:about="https://example.org/mdr-ontology#adddressesIncident">
        <rdfs:domain rdf:resource="https://example.org/mdr-ontology#CorrectiveAction"/>
        <rdfs:range rdf:resource="https://example.org/mdr-ontology#Incident"/>
        <rdfs:label>addresses incident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://example.org/mdr-ontology#affectsDeviceType -->

    <owl:ObjectProperty rdf:about="https://example.org/mdr-ontology#affectsDeviceType">
        <rdfs:domain rdf:resource="https://example.org/mdr-ontology#Risk"/>
        <rdfs:range rdf:resource="https://example.org/mdr-ontology#DeviceType"/>
        <rdfs:label>affects device type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://example.org/mdr-ontology#hasManufacturer -->

    <owl:ObjectProperty rdf:about="https://example.org/mdr-ontology#hasManufacturer">
        <rdfs:domain rdf:resource="https://example.org/mdr-ontology#Device"/>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://example.org/mdr-ontology#hasManufacturer"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://example.org/mdr-ontology#Manufacturer"/>
            </owl:Restriction>
        </rdfs:range>
        <rdfs:label>has manufacturer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://example.org/mdr-ontology#hasRegulatoryFramework -->

    <owl:ObjectProperty rdf:about="https://example.org/mdr-ontology#hasRegulatoryFramework">
        <rdfs:domain rdf:resource="https://example.org/mdr-ontology#Device"/>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://example.org/mdr-ontology#hasRegulatoryFramework"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://example.org/mdr-ontology#RegulatoryFramework"/>
            </owl:Restriction>
        </rdfs:range>
        <rdfs:label>has regulatory framework</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://example.org/mdr-ontology#hasRisk -->

    <owl:ObjectProperty rdf:about="https://example.org/mdr-ontology#hasRisk">
        <rdfs:domain rdf:resource="https://example.org/mdr-ontology#Incident"/>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://example.org/mdr-ontology#hasRisk"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://example.org/mdr-ontology#Risk"/>
            </owl:Restriction>
        </rdfs:range>
        <rdfs:label>has risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://example.org/mdr-ontology#hasRiskProbability -->

    <owl:ObjectProperty rdf:about="https://example.org/mdr-ontology#hasRiskProbability">
        <rdfs:domain rdf:resource="https://example.org/mdr-ontology#Risk"/>
        <rdfs:range rdf:resource="https://example.org/mdr-ontology#ProbabilityLevel"/>
        <rdfs:label>has risk probability</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://example.org/mdr-ontology#hasSeverityLevel -->

    <owl:ObjectProperty rdf:about="https://example.org/mdr-ontology#hasSeverityLevel">
        <rdfs:domain rdf:resource="https://example.org/mdr-ontology#Risk"/>
        <rdfs:range rdf:resource="https://example.org/mdr-ontology#SeverityLevel"/>
        <rdfs:label>has severity level</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://example.org/mdr-ontology#involvesDevice -->

    <owl:ObjectProperty rdf:about="https://example.org/mdr-ontology#involvesDevice">
        <rdfs:domain rdf:resource="https://example.org/mdr-ontology#Incident"/>
        <rdfs:range rdf:resource="https://example.org/mdr-ontology#Device"/>
