    <!-- https://example.org/mdr-ontology#representsRiskClass -->

    <owl:ObjectProperty rdf:about="https://example.org/mdr-ontology#representsRiskClass">
        <rdfs:domain rdf:resource="https://example.org/mdr-ontology#RiskClass"/>
        <rdfs:range rdf:resource="https://example.org/mdr-ontology#Device"/>
