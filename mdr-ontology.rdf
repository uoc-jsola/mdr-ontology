        <rdfs:comment>If a Device instance is implantable then its device type is ImplantableDevice</rdfs:comment>
        <rdfs:label>S1</rdfs:label>
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
